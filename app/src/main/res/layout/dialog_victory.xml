<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    app:cardCornerRadius="28dp"
    app:cardElevation="8dp"
    app:cardBackgroundColor="?attr/colorSurfaceContainer"
    app:strokeWidth="2dp"
    app:strokeColor="?attr/colorSecondary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <TextView
            android:id="@+id/tv_victory_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/victory_title"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary" />

        <TextView
            android:id="@+id/tv_victory_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/victory_subtitle"
            android:textSize="14sp"
            android:textColor="?attr/colorSecondary" />

        <LinearLayout
            android:id="@+id/victory_stars_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/dialog_star1"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_star_filled"
                android:layout_marginEnd="4dp"
                android:contentDescription="Star 1" />

            <ImageView
                android:id="@+id/dialog_star2"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_star_filled"
                android:layout_marginEnd="4dp"
                android:contentDescription="Star 2" />

            <ImageView
                android:id="@+id/dialog_star3"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_star_filled"
                android:contentDescription="Star 3" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tv_victory_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Score: 1000"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface" />

            <TextView
                android:id="@+id/tv_victory_hearts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Hearts Left: 5"
                android:textSize="14sp"
                android:textColor="?attr/colorOutline" />

            <TextView
                android:id="@+id/tv_victory_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Time: 45 seconds"
                android:textSize="14sp"
                android:textColor="?attr/colorOutline" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_next_level"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="@string/next_level"
            android:textSize="16sp"
            android:textAllCaps="false"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_arrow_right" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_victory_home"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/home"
            android:textSize="16sp"
            android:textAllCaps="false"
            style="@style/Widget.Material3.Button.TonalButton"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_arrow_left" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
